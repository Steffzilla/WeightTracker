<?xml version="1.0" encoding="utf-8"?><!--
   Weight entries are health data and must not leave the device unencrypted, so the
   Room database and the preferences (which include the target weight band) are
   excluded from Google cloud backup. Device-to-device transfer stays at its
   include-everything default: it copies directly to the new device without going
   through Google's servers, so a phone migration keeps the data.
   See https://developer.android.com/identity/data/autobackup
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
</data-extraction-rules>
